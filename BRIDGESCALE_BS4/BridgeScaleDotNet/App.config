<configuration>
	<connectionStrings>
		
		<add name="BS4Connection"
		 connectionString="Data Source=(localdb)\MSSQLLocalDB;AttachDbFilename=D:\Data\BS4.mdf;Integrated Security=True;Connect Timeout=30"
		 providerName="System.Data.SqlClient" />
		
	</connectionStrings>
